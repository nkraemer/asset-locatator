    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
